# === Config options
#
clipboard-read = ask
clipboard-write = allow

# === Theming === #
font-family = JetBrainsMono Nerd Font Propo
font-style = Bold
font-size = 9

window-theme=ghostty
window-padding-x = 0 
window-padding-y = 0
window-padding-color = extend 
gtk-custom-css= ./thin-tabs.css
gtk-wide-tabs= false

background = #191919
foreground = #f6f6ee
selection-invert-fg-bg = true
minimum-contrast = 1

custom-shader = ./cursor.glsl
custom-shader-animation = true
cursor-color = #f6f6ee
cursor-text = #000000

palette = 0=#3a3d4b
palette = 1=#f3005f
palette = 2=#97e023
palette = 3=#dfd561
palette = 4=#0e6172
palette = 5=#9c64fe
palette = 6=#57d1ea
palette = 7=#f6f6ee
palette = 8=#696d77
palette = 9=#f3005f
palette = 10=#97e023
palette = 11=#dfd561
palette = 12=#0e6172
palette = 13=#9c64fe
palette = 14=#57d1ea
palette = 15=#f6f6ee

# === Keybinds === #
keybind = clear
keybind = ctrl+alt+comma=reload_config

keybind = ctrl+alt+n=new_window

keybind = ctrl+shift+a=select_all
keybind = shift+left=adjust_selection:left
keybind = shift+up=adjust_selection:up
keybind = shift+down=adjust_selection:down
keybind = shift+right=adjust_selection:right


keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

keybind = ctrl+alt+page_up=scroll_page_up
keybind = ctrl+alt+end=scroll_to_bottom

# Tabs
keybind = ctrl+alt+t=new_tab
keybind = ctrl+alt+tab=next_tab
keybind = ctrl+alt+tab=previous_tab

keybind = ctrl+alt+one=goto_tab:1
keybind = ctrl+alt+two=goto_tab:2
keybind = ctrl+alt+three=goto_tab:3
keybind = ctrl+alt+four=goto_tab:4
keybind = ctrl+alt+five=goto_tab:5
keybind = ctrl+alt+six=goto_tab:6
keybind = ctrl+alt+seven=goto_tab:7
keybind = ctrl+alt+eight=goto_tab:8
keybind = ctrl+alt+nine=goto_tab:9
keybind = ctrl+alt+zero=last_tab


# Splits
keybind = ctrl+alt+o=new_split:right
keybind = ctrl+alt+e=new_split:down
keybind = ctrl+alt+q=close_surface

keybind = ctrl+shift+alt+left=resize_split:left,10
keybind = ctrl+shift+alt+up=resize_split:up,10
keybind = ctrl+shift+alt+down=resize_split:down,10
keybind = ctrl+shift+alt+right=resize_split:right,10

keybind = ctrl+alt+left=goto_split:left
keybind = ctrl+alt+up=goto_split:up
keybind = ctrl+alt+down=goto_split:down
keybind = ctrl+alt+right=goto_split:right

keybind = ctrl+alt+equal=equalize_splits
keybind = ctrl+alt+enter=toggle_split_zoom

keybind = ctrl+alt+zero=reset_font_size
keybind = ctrl+alt+equal=increase_font_size:1
keybind = ctrl+alt+plus=increase_font_size:1
keybind = ctrl+alt+minus=decrease_font_size:1

keybind = ctrl+alt+page_down=jump_to_prompt:1
keybind = ctrl+alt+page_up=jump_to_prompt:-1

keybind = shift+alt+home=scroll_to_top

keybind = ctrl+alt+i=inspector:toggle

